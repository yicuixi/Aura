# Aura AI 环境配置文件
# 复制此文件为 .env 并根据需要修改配置

# ============================================================
# 安全配置（重要！生产环境必须设置）
# ============================================================

# API Key 认证（设置后所有 API 请求需携带 X-API-Key 头）
# 生成方法: python -c "from security import generate_api_key; print(generate_api_key())"
# AURA_API_KEY=aura_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 记忆加密主密钥（设置后 memory.json 自动加密存储）
# 使用任意强密码，首次设置后不要更改，否则已有记忆无法解密
# AURA_MASTER_KEY=your-strong-master-password-here

# 运行环境（production 模式下禁用 /docs 文档页面）
# AURA_ENV=production

# CORS 允许的前端来源（逗号分隔，不设置则使用默认白名单）
# AURA_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================
# Ollama 配置
# ============================================================
OLLAMA_BASE_URL=http://host.docker.internal:11435
OLLAMA_MODEL=qwen2.5:7b

# ============================================================
# SearxNG 搜索引擎配置
# ============================================================
SEARXNG_SECRET=your_random_secret_key_here_please_change_this
SEARXNG_URL=http://searxng:8080

# ============================================================
# API 服务配置 (仅Web API模式使用)
# ============================================================
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# 日志配置
LOG_LEVEL=INFO

# ===== 安全与隐私配置 =====

# API 认证密钥（设置后所有 API 请求需携带 X-API-Key 头）
# 生成方法: python -c "from security import generate_api_key; print(generate_api_key())"
# AURA_API_KEY=aura_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 记忆加密主密码（设置后 memory.json 自动加密存储）
# 建议使用强密码，修改后旧记忆将无法解密
# AURA_MASTER_KEY=your-strong-master-password-here

# CORS 允许的前端域名（逗号分隔，不设置则使用默认白名单）
# AURA_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 运行环境（production 模式下禁用 /docs 接口文档）
# AURA_ENV=production

# ============================================================
# 可选：外部搜索API配置 (作为SearxNG的备用)
# ============================================================
# SERPER_API_KEY=your_serper_api_key
# GOOGLE_API_KEY=your_google_api_key
# GOOGLE_CSE_ID=your_custom_search_engine_id

# ============================================================
# 可选：其他LLM配置
# ============================================================
# OPENAI_API_KEY=your_openai_key
# ANTHROPIC_API_KEY=your_anthropic_key
