{
  "manifest_version": 3,
  "name": "JobHunter AI 填表助手",
  "version": "1.0.0",
  "description": "基于本地 Ollama LLM 的智能简历表单自动填写",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "sidePanel"
  ],

  "host_permissions": [
    "http://localhost:*/*",
    "https://*/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],

  "action": {
    "default_title": "JobHunter AI 填表助手",
    "default_icon": {
      "16": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg"
    }
  },

  "side_panel": {
    "default_path": "sidebar.html"
  },

  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}
